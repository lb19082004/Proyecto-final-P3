@model IEnumerable<SIGENOM.Models.Entities.Empleado>
@{
    ViewData["Title"] = "Empleados";
}

@if (TempData["OK"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["OK"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold mb-0">Lista de Empleados</h5>
    <a asp-action="Crear" class="btn btn-primary">
        <i class="bi bi-person-plus me-1"></i> Nuevo Empleado
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Cédula</th>
                    <th>Nombre</th>
                    <th>Departamento</th>
                    <th>Cargo</th>
                    <th>Salario Base</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in Model)
                {
                    <tr>
                        <td>@e.Cedula</td>
                        <td>@e.NombreCompleto</td>
                        <td>@e.Departamento?.Nombre</td>
                        <td>@e.Cargo?.Nombre</td>
                        <td>RD$ @e.SalarioBase.ToString("N2")</td>
                        <td>
                            <span class="badge @(e.Estado == "Activo" ? "bg-success" : "bg-secondary")">
                                @e.Estado
                            </span>
                        </td>
                        <td>
                            <a asp-action="Detalle" asp-route-id="@e.EmpleadoId" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a asp-action="Editar" asp-route-id="@e.EmpleadoId" class="btn btn-sm btn-outline-warning">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-action="CambiarEstado" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@e.EmpleadoId" />
                                <input type="hidden" name="estado" value="@(e.Estado == "Activo" ? "Inactivo" : "Activo")" />
                                <button class="btn btn-sm @(e.Estado == "Activo" ? "btn-outline-danger" : "btn-outline-success")">
                                    <i class="bi bi-@(e.Estado == "Activo" ? "x" : "check")"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>