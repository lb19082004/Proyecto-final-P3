@{
    ViewData["Title"] = "Dashboard";
}

<div class="row mb-4">
    <div class="col-12">
        <h4 class="fw-bold text-dark">Panel Principal</h4>
        <small class="text-muted">Bienvenido, @User.Identity!.Name</small>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-4">
                <div class="fs-1 fw-bold text-primary">@ViewBag.TotalEmpleados</div>
                <div class="text-muted">Empleados Activos</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-4">
                <div class="fs-1 fw-bold text-success">@ViewBag.TotalDepartamentos</div>
                <div class="text-muted">Departamentos</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-4">
                <div class="fs-1 fw-bold text-warning">@ViewBag.PeriodosAbiertos</div>
                <div class="text-muted">Períodos Abiertos</div>
            </div>
        </div>
    </div>
</div>