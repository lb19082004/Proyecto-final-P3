@model SIGENOM.Models.Entities.Cargo
@{
    ViewData["Title"] = "Nuevo Cargo";
}

<div class="card border-0 shadow-sm" style="max-width:500px;">
    <div class="card-body p-4">
        <h5 class="fw-bold mb-4">Nuevo Cargo</h5>
        <form asp-action="Crear" method="post">
            <div class="mb-3">
                <label class="form-label">Nombre *</label>
                <input asp-for="Nombre" class="form-control" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Departamento *</label>
                <select asp-for="DepartamentoId" asp-items="ViewBag.Departamentos" class="form-select" required>
                    <option value="">-- Seleccionar --</option>
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label">Salario Base</label>
                <input asp-for="SalarioBase" class="form-control" type="number" step="0.01" />
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Guardar</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>