@model IEnumerable<SIGENOM.Models.Entities.Cargo>
@{
    ViewData["Title"] = "Cargos";
}

@if (TempData["OK"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["OK"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold mb-0">Cargos</h5>
    <a asp-action="Crear" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i> Nuevo</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr><th>Nombre</th><th>Departamento</th><th>Salario Base</th><th>Acciones</th></tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td>@c.Nombre</td>
                        <td>@c.Departamento?.Nombre</td>
                        <td>RD$ @c.SalarioBase.ToString("N2")</td>
                        <td><a asp-action="Editar" asp-route-id="@c.CargoId" class="btn btn-sm btn-outline-warning"><i class="bi bi-pencil"></i></a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>