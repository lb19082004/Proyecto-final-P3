@model IEnumerable<SIGENOM.Models.Entities.PeriodoNomina>
@{
    ViewData["Title"] = "Nómina";
}

@if (TempData["OK"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["OK"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold mb-0">Períodos de Nómina</h5>
    <a asp-action="CrearPeriodo" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i> Nuevo Período</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr><th>Descripción</th><th>Desde</th><th>Hasta</th><th>Estado</th><th>Acciones</th></tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td>@p.Descripcion</td>
                        <td>@p.FechaInicio.ToString("dd/MM/yyyy")</td>
                        <td>@p.FechaFin.ToString("dd/MM/yyyy")</td>
                        <td>
                            <span class="badge @(p.Estado == "Abierto" ? "bg-success" : p.Estado == "Cerrado" ? "bg-secondary" : "bg-danger")">
                                @p.Estado
                            </span>
                        </td>
                        <td>
                            @if (p.Estado == "Abierto")
                            {
                                <a asp-action="Procesar" asp-route-id="@p.PeriodoId" class="btn btn-sm btn-primary">
                                    <i class="bi bi-play-fill me-1"></i> Procesar
                                </a>
                            }
                            <a asp-action="Detalle" asp-route-id="@p.PeriodoId" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>