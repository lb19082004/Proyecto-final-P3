<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SIGENOM - @ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        body { background: #f4f6fb; }
        .sidebar {
            width: 240px; min-height: 100vh; background: #1a237e;
            position: fixed; top: 0; left: 0; z-index: 100;
        }
        .sidebar .brand { color: #fff; font-weight: 800; font-size: 1.3rem; padding: 24px 20px 16px; border-bottom: 1px solid rgba(255,255,255,0.1); }
        .sidebar .nav-link { color: rgba(255,255,255,0.8); padding: 10px 20px; border-radius: 8px; margin: 2px 8px; }
        .sidebar .nav-link:hover, .sidebar .nav-link.active { background: rgba(255,255,255,0.15); color: #fff; }
        .sidebar .nav-link i { margin-right: 8px; }
        .main-content { margin-left: 240px; padding: 30px; }
        .topbar { background: #fff; padding: 12px 24px; border-radius: 12px; margin-bottom: 24px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); display: flex; justify-content: space-between; align-items: center; }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="brand"><i class="bi bi-building"></i> SIGENOM</div>
        <nav class="nav flex-column mt-3">
            <a class="nav-link" asp-controller="Dashboard" asp-action="Index"><i class="bi bi-speedometer2"></i> Dashboard</a>
            <a class="nav-link" asp-controller="Empleados" asp-action="Index"><i class="bi bi-people"></i> Empleados</a>
            <a class="nav-link" asp-controller="Departamentos" asp-action="Index"><i class="bi bi-diagram-3"></i> Departamentos</a>
            <a class="nav-link" asp-controller="Cargos" asp-action="Index"><i class="bi bi-briefcase"></i> Cargos</a>
            <a class="nav-link" asp-controller="Nomina" asp-action="Index"><i class="bi bi-cash-stack"></i> Nómina</a>
            <hr style="border-color:rgba(255,255,255,0.2); margin: 8px 16px;" />
            <a class="nav-link" asp-controller="Account" asp-action="Logout"><i class="bi bi-box-arrow-left"></i> Salir</a>
        </nav>
    </div>

    <div class="main-content">
        <div class="topbar">
            <span class="fw-semibold text-muted">@ViewData["Title"]</span>
            <span class="text-muted"><i class="bi bi-person-circle me-1"></i>@User.Identity!.Name</span>
        </div>
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>